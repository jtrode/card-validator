{
  "name": "card-validator",
  "version": "1.0.0",
  "description": "Lightweight, zero-dependency Node.js library for validating payment card data — Luhn algorithm, card type detection, expiration date, and CVV validation.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "keywords": [
    "credit-card",
    "card-validator",
    "luhn",
    "payment",
    "validation"
  ],
  "author": "jrode",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "eslint": "^9.26.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "transform": {}
  }
}
